# combine all files into one csv
allCM <- rbind(CM_04, CM_05, CM_06, CM_21,
                  CM_23, CM_42)

View(allCM)


# Clearing the behavioral information (replace with Reeds code) 
valid_codes <- c("NNOC", "ENIL", "VMUR", "PNAT", "PPYG",
                 "MDAU", "MMYS", "MYSP", "PISP", "PAUR",
                 "NYCT", "NoID", "Noise", "?")

allCM <- allCM %>%
  mutate(
    SPECIES = sapply(`MANUAL ID*`, function(x) {
      parts <- unlist(str_split(x, "_"))      
      parts <- gsub("\\..*", "", parts)        
      codes <- parts[parts %in% valid_codes]   
      if (length(codes) == 0) {
        return(NA)
      } else {
        return(paste(codes, collapse = "_"))   
      }
    })
  ) %>%
  separate_rows(SPECIES, sep = "_", convert = TRUE)


