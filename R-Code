# Change current table to matrix by reducing entries to present/absent format
PRESENCE <- allCM %>% 
  distinct(SITE, MONTH, SPECIES) %>%   
  mutate(PRESENCE = 1) 

# create matrix of (dis)similarity
MATRIX <- PRESENCE %>% 
  pivot_wider(
    names_from = SPECIES,
    values_from = PRESENCE,
    values_fill = 0
  )

View(MATRIX)

# Remove non-species
MATRIX <- MATRIX[, !colnames(MATRIX) %in% c("Noise", "NoID", "?", "MYSP", "NYCT", "PISP")]

View(MATRIX)

# Calculate species richness
richness <- rowSums(MATRIX[, -(1:2)] > 0)
